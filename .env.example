# ==============================================================================
# WILDROVERS ENVIRONMENT CONFIGURATION
# Copy this file to '.env' and adjust the values before running 'docker compose up'
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE SETTINGS
# ------------------------------------------------------------------------------
# Database user (Quarkus application connects as this user)
SQL_USER=root
# Database password (sets root password on MariaDB and connects as root)
SQL_PASSOWRD=your-strong-db-password-here

# ------------------------------------------------------------------------------
# BACKEND OIDC SETTINGS (Authentik)
# ------------------------------------------------------------------------------
AUTHENTIK_AUTH_SERVER_URL=https://auth.example.com/application/o/wildrovers/
AUTHENTIK_CLIENT_ID=your-authentik-client-id
AUTHENTIK_CLIENT_SECRET=your-authentik-client-secret

# ------------------------------------------------------------------------------
# GOOGLE CALENDAR SETTINGS
# ------------------------------------------------------------------------------
# Service Account JSON (Minified, single-line format or file-based mapping)
GOOGLE_CALENDAR_CREDENTIALS='{"type": "service_account", ...}'
GOOGLE_CALENDAR_ID=your-google-calendar-id@group.calendar.google.com

# ------------------------------------------------------------------------------
# FRONTEND VITE SETTINGS (Runtime environment injection)
# ------------------------------------------------------------------------------
# URL where the frontend can reach the REST API (accessible from client browsers)
VITE_API_URL=https://api.example.com
# URL of OIDC Provider for client authentication
VITE_OIDC_AUTHORITY=https://auth.example.com/application/o/wildrovers/
# OIDC Client ID for Frontend
VITE_OIDC_CLIENT_ID=your-frontend-client-id
# OIDC Redirect URL after login
VITE_OIDC_REDIRECT_URI=https://example.com/Login

# Immich Integration
VITE_IMMICH_PROXY_URL=https://fotos.example.com/share/...
VITE_IMMICH_DROP_URL=https://fotos.example.com/invite/...
VITE_IMMICH_KIOSK_URL=https://kiosk.example.com
