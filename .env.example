# # ==============================================================================
# # WILDROVERS ENVIRONMENT CONFIGURATION
# # Copy this file to '.env' and adjust the values before running 'docker compose up'
# # ==============================================================================

# # ------------------------------------------------------------------------------
# # DATABASE SETTINGS
# # ------------------------------------------------------------------------------
# # Database user (Quarkus application connects as this user)
# SQL_USER=root
# SQL_URL=jdbc:mariadb://mariadb:3306/wildrovers
# # Database password (sets root password on MariaDB and connects as root)
# SQL_PASSWORD=your-strong-db-password-here

# # ------------------------------------------------------------------------------
# # BACKEND OIDC SETTINGS (Authentik)
# # ------------------------------------------------------------------------------
# AUTHENTIK_AUTH_SERVER_URL=https://auth.example.com/application/o/wildrovers/
# AUTHENTIK_CLIENT_ID=your-authentik-client-id
# AUTHENTIK_CLIENT_SECRET=your-authentik-client-secret
# AUTHENTIK_PRINCIPAL_CLAIM=preferred_username

# # ------------------------------------------------------------------------------
# # GOOGLE CALENDAR SETTINGS
# # ------------------------------------------------------------------------------
# # Service Account JSON (Minified, single-line format or file-based mapping)
# GOOGLE_CALENDAR_CREDENTIALS='{"type": "service_account", ...}'
# GOOGLE_CALENDAR_ID=your-google-calendar-id@group.calendar.google.com

# # ------------------------------------------------------------------------------
# # JWT KEYS CONFIGURATION
# # ------------------------------------------------------------------------------
# # Absolute host directory containing privateKey.pem and publicKey.pem.
# # JWT_KEYS_DIR=/home/docker/data/wildrovers/certs

# # ------------------------------------------------------------------------------
# # FRONTEND VITE SETTINGS (Runtime environment injection)
# # ------------------------------------------------------------------------------
# # URL where the frontend can reach the REST API (accessible from client browsers)
# VITE_API_URL=https://api.example.com
# # URL of OIDC Provider for client authentication
# VITE_OIDC_AUTHORITY=https://auth.example.com/application/o/wildrovers/
# # OIDC Client ID for Frontend
# VITE_OIDC_CLIENT_ID=your-frontend-client-id
# # OIDC Redirect URL after login
# VITE_OIDC_REDIRECT_URI=https://example.com/Login

# # Immich Integration
# VITE_IMMICH_PROXY_URL=https://fotos.example.com/share/...
# VITE_IMMICH_DROP_URL=https://fotos.example.com/invite/...
# VITE_IMMICH_KIOSK_URL=https://kiosk.example.com

# # ------------------------------------------------------------------------------
# # OPENOBSERVE MONITORING CONFIGURATION
# # ------------------------------------------------------------------------------
# # Public URL of OpenObserve server for the browser client to send logs/RUM
# VITE_OPENOBSERVE_SITE=localhost:5080
# # Ingestion authorization token (Basic Auth base64)
# VITE_OPENOBSERVE_RUM_KEY=replace-with-your-public-rum-key
# VITE_OPENOBSERVE_APP_ID=wildrovers-frontend
# VITE_OPENOBSERVE_ORG=default
# VITE_OPENOBSERVE_INSECURE_HTTP=true
# VITE_OPENOBSERVE_ENABLED=true

# # Token used by the backend to write traces/metrics to OpenObserve
# OPENOBSERVE_ENDPOINT=http://localhost:5080/api/default
# OPENOBSERVE_TOKEN=YWRtaW5AZXhhbXBsZS5jb206WW91clNlY3VyZVBhc3N3b3JkMTIz
# ZO_ROOT_USER_EMAIL=admin@example.com
# ZO_ROOT_USER_PASSWORD=replace-with-a-long-random-password
# ZO_RUM_ENABLED=true
# ZO_RUM_CLIENT_TOKEN=replace-with-a-random-token

# # ------------------------------------------------------------------------------
# # APPLICATION BASE URL & MAIL CONFIGURATION
# # ------------------------------------------------------------------------------
# # The public URL of the backend API used for CORS and generating verification codes
# APP_BASE_URL=https://api.wild-rovers.de
# APP_FRONTEND_URL=https://wild-rovers.de
# CORS_ORIGINS=https://wild-rovers.de
# TRUSTED_PROXIES=172.20.0.0/16
# OTEL_DISABLED=false
# OTEL_LOG_LEVEL=WARN
# RATE_LIMITER_ENABLED=true
# # Whether to mock sending emails. Set to false to send real emails via SMTP
# MAILER_MOCK=false
# # General SMTP Mailer settings
# MAILER_FROM=wild-rovers.wtf@gmail.com
# MAILER_HOST=smtp.gmail.com
# MAILER_PORT=587
# MAILER_SSL=false
# MAILER_START_TLS=REQUIRED
# MAILER_USERNAME=your-smtp-username
# MAILER_PASSWORD=your-smtp-password
# MAILER_AUTH_METHODS=DIGEST-MD5 CRAM-SHA256 CRAM-SHA1 CRAM-MD5 PLAIN LOGIN
# # Gmail / Google Workspace username for SMTP email sending (Legacy / Fallback for username/password)
# EMAIL_GOOGLE_USERNAME=wild-rovers.wtf@gmail.com
# EMAIL_GOOGLE_PASSWORD=your-google-app-password
